{
  "name": "arch-visualizer",
  "displayName": "Arch Visualizer",
  "description": "Interactive architecture diagram visualizer with Mermaid viewer and Kanban planning board",
  "version": "0.1.0",
  "publisher": "baonc",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arch-visualizer.open",
        "title": "Arch Visualizer: Open",
        "icon": "$(circuit-board)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "arch-visualizer.open"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "~5.3.0"
  }
}
